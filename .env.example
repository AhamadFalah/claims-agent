# Copy to .env and fill in. Every key is OPTIONAL — the app runs with stubs when
# a key is missing, so the demo works offline. Add keys to go live with each tool.

# Gemini (Google DeepMind) — claim extraction
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Tavily — enrichment search (fallback if AfterShip unset)
TAVILY_API_KEY=

# AfterShip — real carrier tracking verification (preferred over Tavily)
AFTERSHIP_API_KEY=
AFTERSHIP_SLUG=myhermes-uk
AFTERSHIP_VERSION=2026-01

# Attio — live case board (REST v2)
ATTIO_API_KEY=
ATTIO_CLAIM_OBJECT=claims

# Firebase / Firestore — claim validation docs (VALIDATING / VALIDATED / ERROR).
# Used by the n8n 'outcome-replay' workflow's Firestore nodes (REST API).
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# Mubit / Minima — model routing
MUBIT_API_KEY=

# Where mock-dispatched CSVs are written
BATCH_DIR=data/batches

# n8n -> FastAPI base URL. The 'outcome-replay' workflow calls
# {AGENT_BASE_URL}/claims/{correlation_id}/process and {AGENT_BASE_URL}/outcomes/ingest.
# Set this in n8n (not the app) to your public agent URL (tunnel / Render).
AGENT_BASE_URL=http://localhost:8000
